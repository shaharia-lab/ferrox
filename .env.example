# Copy this file to .env and fill in your values.
# .env is loaded automatically by `make run`.
# Never commit .env to version control.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY_2=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Z.AI GLM ─────────────────────────────────────────────────────────────────
GLM_API_KEY=

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Ferrox virtual keys ───────────────────────────────────────────────────────
PROXY_KEY_TOKENBANK=sk-proxy-dev-key
PROXY_KEY_APP=sk-proxy-app-key

# ── Telemetry ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=text
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
